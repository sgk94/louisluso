# ===========================================
# Zoho OAuth — API access for Inventory, Books, CRM
# ===========================================
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
# Optional: defaults to https://www.zohoapis.com
# ZOHO_API_BASE_URL=https://www.zohoapis.com

# ===========================================
# Clerk — Authentication
# ===========================================
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ===========================================
# Upstash Redis — Rate limiting & caching
# ===========================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===========================================
# Cloudinary — Image hosting
# ===========================================
CLOUDINARY_CLOUD_NAME=

# ===========================================
# Gmail — Email automation (OAuth2)
# ===========================================
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Where partner application notifications are sent.
# Dev/test: a personal inbox (e.g. shawn@louisluso.com).
# Go-live: switch to admin@louisluso.com (or comma to both).
PARTNER_APP_NOTIFY_EMAIL=

# ===========================================
# Mapbox — Dealer locator map
# ===========================================
NEXT_PUBLIC_MAPBOX_TOKEN=
