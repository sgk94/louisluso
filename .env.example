WC_CONSUMER_KEY=ck_your_key_here
WC_CONSUMER_SECRET=cs_your_secret_here
WC_STORE_URL=https://louisluso.com

# Transport: "smtp" or "gmail"
EMAIL_TRANSPORT=gmail

# SMTP (required when EMAIL_TRANSPORT=smtp)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=cs@louisluso.com
EMAIL_PASS=your-app-password

# Gmail API (required when EMAIL_TRANSPORT=gmail)
GMAIL_CLIENT_ID=your-workspace-client-id
GMAIL_CLIENT_SECRET=your-workspace-client-secret

# Shared
EMAIL_FROM_NAME=Ken Yoon
EMAIL_FROM_ADDRESS=cs@louisluso.com
EMAIL_MAX_PER_HOUR=50
EMAIL_MAX_PER_DAY=2000
EMAIL_DELAY_MS=2000
